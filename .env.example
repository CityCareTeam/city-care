# Copier ce fichier en `.env` sur le serveur de prod et remplir les valeurs.
#   cp .env.example .env

# --- Base de données applicative ---
POSTGRES_DB=citycare
POSTGRES_USER=citycare
POSTGRES_PASSWORD=change-me

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_API_CLIENT_SECRET=change-me

# --- MinIO ---
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=citycare-photos
MINIO_USE_SSL=true
# URL publique MinIO (OBLIGATOIRE) — l'adresse vue par le navigateur, pas localhost
MINIO_PUBLIC_BASE_URL=https://storage.citycare.fr
